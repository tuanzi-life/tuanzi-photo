# Fastify backend runtime environment

# Runtime mode. Set to "production" when the backend should serve
# apps/frontend/dist via @fastify/static.
NODE_ENV=development

# Fastify listen address and port.
HOST=0.0.0.0
PORT=4010

# Python executable used to run the Waveshare render script.
EPD_PYTHON_BIN=python3

# Timeout for a single e-ink render/refresh job in milliseconds.
EPD_RENDER_TIMEOUT_MS=180000

# Photo storage (base on aliyun ali-oss)
OSS_REGION=""
OSS_ENDPOINT=""
OSS_BUCKET=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
