{
  "name": "backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "imports": {
    "#paths": "./src/paths.js"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc && node scripts/copy-driver.mjs",
    "build:pi": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--max-old-space-size=192\" tsc && node scripts/copy-driver.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "@tuanzi-photo/shared-types": "workspace:*",
    "ali-oss": "^6.23.0",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0"
